        </div>
        <!-- Row 2: two side-by-side -->
        <div class="overflow-hidden rounded-[1.25rem]">
          <img src="/images/banner2.png" alt="DatingMet banner" class="h-36 w-full object-cover sm:h-40" />
        </div>
        <div class="overflow-hidden rounded-[1.25rem]">
          <img src="/images/banner3.png" alt="DatingMet banner" class="h-36 w-full object-cover sm:h-40" />
        </div>
        <!-- Row 3: two side-by-side -->
        <div class="overflow-hidden rounded-[1.25rem]">
          <img src="/images/banner4.png" alt="DatingMet banner" class="h-36 w-full object-cover sm:h-40" />
        </div>
        <div class="overflow-hidden rounded-[1.25rem]">
          <img src="/images/banner1.png" alt="Couple in field" class="h-36 w-full object-cover sm:h-40" />
        </div>
      </div>
      
    </div>
  </div>

  <!-- Mobile-only stats strip pinned to bottom -->
  
</section>

