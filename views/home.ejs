<!-- MEET PEOPLE SAME AS YOUR CHOICE -->
<section class="profiles-section">
  <h2>Meet people same as your choice</h2>
  <p class="subtitle">Check out our highlighted and verified profiles.</p>

  <%
    const allProfiles = [];
    const maxBrides = Math.min((brides || []).length, 4);
    const maxGrooms = Math.min((grooms || []).length, 4);
    for (let i = 0; i < maxGrooms; i++) allProfiles.push(grooms[i]);
    for (let i = 0; i < maxBrides; i++) allProfiles.push(brides[i]);
  %>

  <div class="profiles-grid">
    <% allProfiles.slice(0, 8).forEach(p => { %>
      <a href="/people/<%= p._id %>" class="profile-card">
        <div style="position:relative;">
          <img
            src="<%= p.image || '/images/default-profile.png' %>"
            alt="<%= p.first_name %>"
            style="<%= p.isBlurred ? 'filter:blur(25px) brightness(0.5);transform:scale(1.1);' : '' %>"
          />
          <% if (p.isBlurred) { %>
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
              <span style="background:rgba(0,0,0,0.7);color:#fff;font-size:0.75rem;padding:4px 12px;border-radius:999px;">Private Photo</span>
            </div>
          <% } %>
        </div>
        <h3><%= p.first_name %> <%= p.last_name %></h3>
        <p>User Id: <%= p._id.toString().slice(-4) %></p>
        <p><%= p.religion || "Hindu" %>, <%= p.age || 24 %></p>
      </a>
    <% }) %>
  </div>
</section>

<!-- BLOG SECTION -->
<section class="blog-section">
  <h2 class="big-heading">Real People. Real Connections. Real Love Stories.</h2>
  <p class="see-blogs">See Our Blogs</p>

  <% const homeBlogs = (typeof blogs !== 'undefined' && blogs) ? blogs.slice(0, 6) : []; %>

  <% if (homeBlogs.length > 0) { %>
  <div style="position:relative;max-width:1100px;margin:0 auto;">
    <button class="blog-arrow left" id="blogPrev">&#9664;</button>
    <div class="blog-carousel-wrap">
      <div class="blog-carousel" id="blogCarousel">
        <% homeBlogs.forEach(blog => { %>
          <div class="blog-card">
            <% if (blog.coverImage) { %>
              <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" />
            <% } else { %>
              <div style="height:190px;background:#e8d0f8;display:flex;align-items:center;justify-content:center;">
                <i class="fa-solid fa-heart" style="color:#c0006a;font-size:2.5rem;"></i>
              </div>
            <% } %>
            <div class="blog-card-body">
              <h3><%= blog.title %></h3>
              <p class="meta">By DatingMet&bull; <%= blog.createdAt.toDateString() %></p>
              <a href="/blogs/<%= blog._id %>">Read More &rarr;</a>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <button class="blog-arrow right" id="blogNext">&#9654;</button>
  </div>
  <% } else { %>
    <p style="text-align:center;color:#888;margin-top:20px;">No blogs published yet. <a href="/blogs" style="color:#c0006a;">View Blogs</a></p>
  <% } %>
</section>

<!-- FAQ SECTION -->
