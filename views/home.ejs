<%- include("layouts/footer.ejs") %>

<script>
  // Hero slider
  const heroSlides = document.querySelectorAll(".hero-slide");
  let heroIndex = 0;
  if (heroSlides.length > 1) {
    setInterval(() => {
      heroSlides[heroIndex].classList.remove("active");
      heroIndex = (heroIndex + 1) % heroSlides.length;
      heroSlides[heroIndex].classList.add("active");
    }, 4500);
  }

  // Story carousel
  const storyCarousel = document.getElementById("storyCarousel");
  const storySlides = storyCarousel ? storyCarousel.children.length : 0;
  let storyIndex = 0;
  function updateStoryCarousel() {
    if (!storyCarousel) return;
    storyCarousel.style.transform = `translateX(-${storyIndex * 100}%)`;
  }
  document.getElementById("prevStory")?.addEventListener("click", () => {
    storyIndex = storyIndex === 0 ? storySlides - 1 : storyIndex - 1;
    updateStoryCarousel();
  });
  document.getElementById("nextStory")?.addEventListener("click", () => {
    storyIndex = storyIndex === storySlides - 1 ? 0 : storyIndex + 1;
    updateStoryCarousel();
  });

  // Blog carousel
  const blogCarousel = document.getElementById("blogCarousel");
  let blogIndex = 0;
  const blogCardWidth = blogCarousel ? (blogCarousel.children[0]?.offsetWidth + 20) : 0;
  const totalBlogCards = blogCarousel ? blogCarousel.children.length : 0;

  document.getElementById("blogPrev")?.addEventListener("click", () => {
    blogIndex = Math.max(0, blogIndex - 1);
    blogCarousel.style.transform = `translateX(-${blogIndex * blogCardWidth}px)`;
  });
  document.getElementById("blogNext")?.addEventListener("click", () => {
    blogIndex = Math.min(totalBlogCards - 3, blogIndex + 1);
    blogCarousel.style.transform = `translateX(-${blogIndex * blogCardWidth}px)`;
  });

  // FAQ toggle
  function toggleFaq(questionEl) {
    const answer = questionEl.nextElementSibling;
    const btn = questionEl.querySelector('.faq-toggle');
    const isOpen = answer.classList.contains('open');
    // Close all
    document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
    document.querySelectorAll('.faq-toggle').forEach(b => { b.classList.remove('open'); b.textContent = '+'; });
    if (!isOpen) {
      answer.classList.add('open');
      btn.classList.add('open');
      btn.textContent = '−';
    }
  }
</script>
