<%- layout("/layouts/navbar.ejs") %>
<script src="https://cdn.tailwindcss.com"></script>
<%
  const websiteImages = showcaseImages || [];
  const heroImages = websiteImages.slice(0, 5);
  const moodImages = websiteImages.slice(5, 11);
  const storyImages = websiteImages.slice(11, 17);
  const cardImageA = heroImages[0] || websiteImages[0];
  const cardImageB = heroImages[1] || websiteImages[1] || websiteImages[0];
  const cardImageC = heroImages[2] || websiteImages[2] || websiteImages[0];
  const safetyImage = heroImages[3] || websiteImages[3] || websiteImages[0];
%>
<style>
  .hero-slide {
    opacity: 0;
    transition: opacity 900ms ease;
  }

  .hero-slide.active {
    opacity: 1;
  }

  .glass-panel {
    backdrop-filter: blur(18px);
    background: rgba(15, 23, 42, 0.45);
  }
</style>

<section class="relative min-h-[92vh] overflow-hidden bg-slate-950">
  <div id="heroSlider" class="absolute inset-0">
    <% heroImages.forEach((image, index) => { %>
      <div class="hero-slide <%= index === 0 ? 'active' : '' %> absolute inset-0">
        <img
          src="<%= image.src %>"
          alt="<%= image.alt %>"
          class="h-full w-full object-cover"
        />
      </div>
    <% }) %>
  </div>

  <div class="absolute inset-0 bg-gradient-to-br from-slate-950/85 via-violet-950/55 to-fuchsia-900/60"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.14),_transparent_35%)]"></div>

  <div class="relative z-10 mx-auto flex min-h-[92vh] max-w-7xl flex-col justify-center gap-10 px-6 py-16 lg:flex-row lg:items-center">
    <div class="max-w-2xl text-white">
      <span class="inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm tracking-[0.3em] text-white/80 uppercase">
        Real Connections
      </span>
      <h1 class="mt-6 text-5xl font-black leading-tight sm:text-6xl">
        Turn chemistry into
        <span class="text-violet-300">something real.</span>
      </h1>
      <p class="mt-5 max-w-xl text-lg text-white/75 sm:text-xl">
        A dating-first experience with genuine profiles, private conversations, and a faster path from match to meetup.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/people"
          class="rounded-full bg-violet-600 px-8 py-3 text-base font-semibold text-white shadow-lg shadow-violet-600/30 transition hover:bg-violet-500"
        >
          Browse Matches
        </a>
        <a
          href="/login"
          class="rounded-full border border-white/20 bg-white/10 px-8 py-3 text-base font-semibold text-white transition hover:bg-white/20"
        >
          Start Free
        </a>
      </div>
    </div>

    <div class="glass-panel w-full max-w-xl rounded-[2rem] border border-white/10 p-5 text-white shadow-2xl shadow-black/30">
      <div class="grid grid-cols-2 gap-4">
        <% moodImages.slice(0, 4).forEach((image, index) => { %>
          <div class="<%= index === 0 ? 'col-span-2' : '' %> overflow-hidden rounded-[1.5rem]">
            <img
              src="<%= image.src %>"
              alt="<%= image.alt %>"
              class="h-44 w-full object-cover <%= index === 0 ? 'sm:h-60' : 'sm:h-44' %>"
            />
          </div>
        <% }) %>
      </div>
      <div class="mt-4 grid grid-cols-3 gap-3 text-center">
        <div class="rounded-2xl bg-white/10 p-4">
          <div class="text-2xl font-bold text-violet-300">11 Days</div>
          <div class="mt-1 text-sm text-white/70">free access</div>
        </div>
        <div class="rounded-2xl bg-white/10 p-4">
          <div class="text-2xl font-bold text-violet-300">OTP</div>
          <div class="mt-1 text-sm text-white/70">instant sign-in</div>
        </div>
        <div class="rounded-2xl bg-white/10 p-4">
          <div class="text-2xl font-bold text-violet-300">100%</div>
          <div class="mt-1 text-sm text-white/70">real intent</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto -mt-10 max-w-6xl px-4 sm:px-6 relative z-10">
  <div class="rounded-[2rem] bg-white p-6 shadow-2xl shadow-violet-100 sm:p-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-violet-600">Free Access Window</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900">Create your profile and unlock the first 11 days free.</h2>
        <p class="mt-3 max-w-2xl text-base text-slate-600">
          Start chatting, shortlist profiles, and explore serious dating matches before choosing a paid plan.
        </p>
      </div>
      <a
        href="/profile/edit"
        class="inline-flex items-center justify-center rounded-full bg-slate-900 px-7 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
      >
        Create Profile
      </a>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
  <div class="mb-10 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-violet-600">Why People Join</p>
    <h2 class="mt-3 text-4xl font-bold text-slate-900">Built like a dating site, filtered like a trusted network.</h2>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    <div class="rounded-[1.75rem] bg-white p-6 shadow-lg shadow-slate-200/60">
      <img src="<%= cardImageA?.src %>" alt="<%= cardImageA?.alt || 'Dating image' %>" class="mb-5 h-56 w-full rounded-[1.25rem] object-cover" />
      <h3 class="text-xl font-semibold text-slate-900">Photo-first attraction</h3>
      <p class="mt-3 text-slate-600">Lead with a strong visual impression and move into real conversations quickly.</p>
    </div>
    <div class="rounded-[1.75rem] bg-violet-50 p-6 shadow-lg shadow-violet-100/70">
      <img src="<%= cardImageB?.src %>" alt="<%= cardImageB?.alt || 'Dating image' %>" class="mb-5 h-56 w-full rounded-[1.25rem] object-cover" />
      <h3 class="text-xl font-semibold text-slate-900">Verified, low-noise profiles</h3>
      <p class="mt-3 text-slate-600">Cleaner trust signals, serious intent, and fewer fake interactions before you invest time.</p>
    </div>
    <div class="rounded-[1.75rem] bg-fuchsia-50 p-6 shadow-lg shadow-fuchsia-100/70">
      <img src="<%= cardImageC?.src %>" alt="<%= cardImageC?.alt || 'Dating image' %>" class="mb-5 h-56 w-full rounded-[1.25rem] object-cover" />
      <h3 class="text-xl font-semibold text-slate-900">Private chat and calls</h3>
      <p class="mt-3 text-slate-600">Move from browsing to chat, voice, and video inside the same experience.</p>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6">
  <div class="grid gap-8 overflow-hidden rounded-[2rem] bg-slate-900 p-6 text-white shadow-2xl shadow-slate-300/30 lg:grid-cols-[1.1fr_0.9fr] lg:p-10">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-violet-300">Safe Dating</p>
      <h2 class="mt-3 text-3xl font-bold">Meet with confidence, not guesswork.</h2>
      <p class="mt-4 max-w-2xl text-white/70">
        Keep conversations inside the platform until you trust the match. Share slowly, verify intent, and avoid sending personal details too early.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl bg-white/10 p-4">
          <div class="text-lg font-semibold">Private photos</div>
          <p class="mt-2 text-sm text-white/70">Control what each visitor sees.</p>
        </div>
        <div class="rounded-2xl bg-white/10 p-4">
          <div class="text-lg font-semibold">Verified identity</div>
          <p class="mt-2 text-sm text-white/70">Build trust before sharing numbers.</p>
        </div>
        <div class="rounded-2xl bg-white/10 p-4">
          <div class="text-lg font-semibold">In-app messaging</div>
          <p class="mt-2 text-sm text-white/70">Talk safely before meeting offline.</p>
        </div>
      </div>
    </div>
    <div class="overflow-hidden rounded-[1.75rem]">
      <img
        src="<%= safetyImage?.src %>"
        alt="<%= safetyImage?.alt || 'Dating safety' %>"
        class="h-full min-h-[320px] w-full object-cover"
      />
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto py-8 px-6">
  <h2 class="text-3xl font-bold text-center text-violet-700">Featured Brides</h2>
  <p class="text-center text-gray-500 mt-2">Check out our highlighted and verified bride profiles.</p>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-10">
    <% brides.forEach(bride => { %>
      <a href="/people/<%= bride._id %>" class="bg-white rounded-xl shadow hover:shadow-lg transition p-4 text-center">
        <div class="relative">
          <img
            src="<%= bride.image || '/images/default-profile.png' %>"
            class="w-full h-52 object-cover rounded-lg transition <%= bride.isBlurred ? 'blur-[25px] scale-110 brightness-50 contrast-125' : '' %>"
          />
          <% if (bride.isBlurred) { %>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="bg-black/70 text-white text-xs px-3 py-1 rounded-full">Private Photo</span>
            </div>
          <% } %>
        </div>
        <h3 class="text-violet-700 font-semibold mt-3"><%= bride.first_name %> <%= bride.last_name %></h3>
        <p class="text-sm text-gray-500">User Id: <%= bride._id.toString().slice(-4) %></p>
        <p class="text-xs text-gray-500 mt-1"><%= bride.religion || "Hindu" %>, <%= bride.age || 24 %></p>
      </a>
    <% }) %>
  </div>
</section>

<section class="max-w-7xl mx-auto py-16 px-6">
  <h2 class="text-3xl font-bold text-center text-violet-700">Featured Grooms</h2>
  <p class="text-center text-gray-500 mt-2">Check out our highlighted and verified groom profiles.</p>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-10">
    <% grooms.forEach(groom => { %>
      <a href="/people/<%= groom._id %>" class="bg-white rounded-xl shadow hover:shadow-lg transition p-4 text-center">
        <img
          src="<%= groom.image || '/images/default-profile.png' %>"
          class="w-full h-52 object-cover rounded-lg <%= groom.isBlurred ? 'blur-[20px] scale-110 brightness-75' : '' %>"
        />
        <h3 class="text-violet-700 font-semibold mt-3"><%= groom.first_name %> <%= groom.last_name %></h3>
        <p class="text-sm text-gray-500">User Id: <%= groom._id.toString().slice(-4) %></p>
        <p class="text-xs text-gray-500 mt-1"><%= groom.religion || "Hindu" %>, <%= groom.age || 24 %></p>
      </a>
    <% }) %>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
  <div class="mb-8 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-violet-600">Moments</p>
    <h2 class="mt-3 text-4xl font-bold text-slate-900">Visual stories from the vibe you want to build.</h2>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="overflow-hidden rounded-[2rem] bg-white shadow-xl shadow-slate-200/70">
      <div id="storyCarousel" class="flex transition-transform duration-500">
        <% storyImages.forEach((image) => { %>
          <div class="min-w-full">
            <img
              src="<%= image.src %>"
              alt="<%= image.alt %>"
              class="h-[420px] w-full object-cover"
            />
          </div>
        <% }) %>
      </div>
    </div>
    <div class="flex flex-col justify-between rounded-[2rem] bg-violet-50 p-8">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-violet-600">Content</p>
        <h3 class="mt-3 text-3xl font-bold text-slate-900">Style the brand around real faces and warm energy.</h3>
        <p class="mt-4 text-slate-600">
          Your WhatsApp image set now drives the main visual identity of the site. Once the files are copied into `public/images`, these sections will render them automatically.
        </p>
      </div>
      <div class="mt-8 flex gap-3">
        <button id="prevStory" class="h-11 w-11 rounded-full bg-white text-xl text-slate-900 shadow-md transition hover:bg-slate-100">←</button>
        <button id="nextStory" class="h-11 w-11 rounded-full bg-slate-900 text-xl text-white shadow-md transition hover:bg-slate-800">→</button>
      </div>
    </div>
  </div>
</section>

<%- include("layouts/footer.ejs") %>

<script>
  const heroSlides = document.querySelectorAll(".hero-slide");
  let heroIndex = 0;

  if (heroSlides.length > 1) {
    setInterval(() => {
      heroSlides[heroIndex].classList.remove("active");
      heroIndex = (heroIndex + 1) % heroSlides.length;
      heroSlides[heroIndex].classList.add("active");
    }, 4500);
  }

  const storyCarousel = document.getElementById("storyCarousel");
  const storySlides = storyCarousel ? storyCarousel.children.length : 0;
  const prevStory = document.getElementById("prevStory");
  const nextStory = document.getElementById("nextStory");
  let storyIndex = 0;

  function updateStoryCarousel() {
    if (!storyCarousel) return;
    storyCarousel.style.transform = `translateX(-${storyIndex * 100}%)`;
  }

  prevStory?.addEventListener("click", () => {
    storyIndex = storyIndex === 0 ? storySlides - 1 : storyIndex - 1;
    updateStoryCarousel();
  });

  nextStory?.addEventListener("click", () => {
    storyIndex = storyIndex === storySlides - 1 ? 0 : storyIndex + 1;
    updateStoryCarousel();
  });
</script>
