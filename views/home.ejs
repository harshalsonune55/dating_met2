        <img src="<%= image.src %>" alt="<%= image.alt %>" class="h-full w-full object-cover object-center" />
      </div>
    <% }) %>
  </div>
  <div class="hero-overlay absolute inset-0 bg-gradient-to-br from-slate-950/85 via-violet-950/55 to-fuchsia-900/60"></div>
  <div class="hero-content-col relative z-10 mx-auto flex min-h-[92vh] max-w-7xl flex-col justify-center gap-10 px-6 py-16 lg:flex-row lg:items-center">
    <div class="max-w-2xl text-white">
      <span class="inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm tracking-[0.3em] text-white/80 uppercase">Real Connections</span>
      <h1 class="hero-h1 mt-6 text-5xl font-black leading-tight sm:text-6xl">
        Turn chemistry into <span class="text-violet-300">something real.</span>
      </h1>
      <p class="hero-sub mt-5 max-w-xl text-lg text-white/75 sm:text-xl">
        A dating-first experience with genuine profiles, private conversations, and a faster path from match to meetup.
      </p>
      <div class="hero-btns mt-8 flex flex-wrap gap-4">
        <a href="/people" class="rounded-full bg-violet-600 px-8 py-3 text-base font-semibold text-white shadow-lg shadow-violet-600/30 transition hover:bg-violet-500">Browse Matches</a>
