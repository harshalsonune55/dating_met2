<%- layout("layouts/navbar.ejs") %>

<div class="max-w-md mx-auto mt-16 bg-white p-8 rounded-2xl shadow">

  <h2 class="text-2xl font-bold mb-6 text-center">
    Makeup User Login
  </h2>

  <% if (typeof error !== "undefined") { %>
    <p class="text-red-500 mb-4 text-center">
      <%= error %>
    </p>
  <% } %>

  <form action="/login-password" method="POST" class="space-y-4">

    <input
      type="text"
      name="phone"
      placeholder="Enter Phone"
      required
      class="w-full border p-3 rounded"
    />

    <input
      type="password"
      name="password"
      placeholder="Enter Password"
      required
      class="w-full border p-3 rounded"
    />

    <button
      type="submit"
      class="w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700"
    >
      Login
    </button>

  </form>

  <p class="text-sm text-gray-500 mt-4 text-center">
    This login is for internal / makeup users only
  </p>

</div>