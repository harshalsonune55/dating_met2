<%- layout("layouts/navbar.ejs") %>

<div style="background:#f8f6ff;min-height:100vh;padding:50px 20px;">
  <div style="max-width:900px;margin:0 auto;background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,0.08);padding:50px 48px;">

    <h1 style="font-size:2.2rem;font-weight:800;text-align:center;color:#3d0066;margin-bottom:10px;">Safety Guidelines</h1>
    <p style="text-align:center;color:#888;font-size:0.9rem;margin-bottom:40px;">Making User Experience Safe at DatingMet</p>

    <div style="color:#444;font-size:0.97rem;line-height:1.85;">

      <p style="margin-bottom:20px;">At DatingMet, we aspire to provide Users with recommendations and suggestions for matchmaking which could be most compatible based on the information provided by the User. Finding a highly compatible match and being in a lasting relationship online is a likely probability through DatingMet. However, the choices and decisions in the context always rest with the User. We are committed to assisting by providing guidance and support.</p>

      <p style="margin-bottom:28px;">User's judgment, choices, decisions and instincts are necessary at all times and cannot override the recommendations We make in good faith. We highly stress that there is no substitution for acting with caution and best judgement.</p>

      <% const guidelines = [
        {
          num: "1",
          title: "Please do not ignore your own Best Judgment",
          body: "DatingMet monitors User account activity and investigates all complaints, however, verifying criminal background of each account is not possible. Users should be aware of red flags: someone who immediately requests to talk on an outside messaging service; someone who claims destiny brought you together at early stages; someone who is always traveling and can never meet in person; anyone who asks for money or financial assistance; or someone who pushes the relationship to progress faster than your comfort level. If you feel suspicious about any match, end the interaction immediately."
        },
        {
          num: "2",
          title: "NEVER Share Financial Information or Certain Personal Information",
          body: "NEVER give credit card number or bank information or any passwords. NEVER share information which could reveal your passwords like mother's maiden name, date of birth, etc. NEVER send money to someone you meet online or to someone the person requests to, especially by wire transfer. Immediately stop communicating with anyone who pressures you for personal or financial information."
        },
        {
          num: "3",
          title: "Always Protect Your Account at DatingMet",
          body: "When accessing your account from a public or shared computer, use caution and be aware of your surroundings so that others are not able to view or record your password or other personal information."
        },
        {
          num: "4",
          title: "Be very Cautious When Sharing Personal Information",
          body: "We strongly encourage Users to be cautious when sharing personal information that could reveal identity. Never include last name, email address, home address, telephone number, place of work or any other identifying information in initial messages. Get to know a match well before sharing personal details and only if you feel confident to do so."
        },
        {
          num: "5",
          title: "Do Your Own Research on any recommended match",
          body: "While we conduct certain types of screening and utilize a variety of verification methods, personal safety and securing a future in a relationship is always one's own responsibility. We urge Users to conduct any verification and screening they wish to perform for their safety. This can include typing a match's name into a search engine or using a paid service to obtain a full background report."
        },
        {
          num: "6",
          title: "Use Caution When Deciding to Click on Any URL Link",
          body: "If any match shares a URL link, always use good judgment and be cautious when deciding to click on any URL links. Be aware of links that lead to web pages which look similar or identical to DatingMet's homepage, including its log-in fields. These links are typically sent as attempts to phish for log-in information. Report any such phishing attempts to DatingMet immediately at care@DatingMet.com."
        },
        {
          num: "7",
          title: "Take Your Time to decide on a match",
          body: "Online communication can sometimes accelerate one's sense of comfort and intimacy. DatingMet offers a secure anonymous messaging system for use for as long as required for getting to know the recommended match. Move slowly and pay attention to the reality of the relationship."
        },
        {
          num: "8",
          title: "Make Your Meetings Safe",
          body: "Meeting in person can be exciting but always exercise reasonable caution. Choose the time and place of meeting — meet in a public place during the day. It could be best to abstain from alcohol consumption in the first few meetings. Use your own transportation for initial meetings. Always share your plans with a friend or family member. Carry a fully charged mobile phone with easily accessible emergency numbers."
        },
        {
          num: "9",
          title: "Always be Respectful and Kind",
          body: "Users should always be respectful and treat matches as you would want them to treat you. Not every match is going to be right for you — closing communication with matches is a natural and healthy part of the process. If you feel the need to end communication, be honest, direct and polite. The sooner you address this determination, the better."
        },
        {
          num: "10",
          title: "Report Concerns About a Match to DatingMet",
          body: "DatingMet works diligently to close Users who misrepresent to other Users on our Site, and member complaints are taken seriously. If you have concerns about a particular match, please do not hesitate to contact us so that appropriate steps can be taken to keep DatingMet safe. Email your concerns to: care@DatingMet.com."
        },
      ]; %>

      <% guidelines.forEach(g => { %>
        <div style="margin-bottom:28px;border-left:3px solid #c0006a;padding-left:18px;">
          <h2 style="font-size:1.05rem;font-weight:700;color:#3d0066;margin-bottom:8px;"><%= g.num %>. <%= g.title %></h2>
          <p style="margin:0;color:#555;"><%= g.body %></p>
        </div>
      <% }) %>

      <div style="background:#fff0f0;border-left:4px solid #c0006a;padding:16px 20px;border-radius:8px;margin-top:30px;">
        <p style="margin:0;font-size:0.9rem;color:#333;">
          We hope these guidelines will help to make your experience a success, and help you find a life partner / soul mate, as so many others. For any concerns, email us at <a href="mailto:care@DatingMet.com" style="color:#c0006a;font-weight:600;">care@DatingMet.com</a>
        </p>
      </div>

    </div>
  </div>
</div>

<%- include("layouts/footer.ejs") %>
