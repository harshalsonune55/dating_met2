<%- layout("/layouts/navbar.ejs") %>

<div class="max-w-xl mx-auto mt-12 bg-white p-8 rounded-2xl shadow">
  <h2 class="text-2xl font-bold mb-4">Government ID Verification</h2>

  <p class="text-gray-600 mb-6">
    Upload a valid government-issued ID. Our team will verify it within 24–48 hours.
  </p>

  <form
    action="/profile/verify"
    method="POST"
    enctype="multipart/form-data"
    class="space-y-4"
  >

    <!-- FILE INPUT -->
    <input
      type="file"
      name="govtId"
      accept="image/*"
      required
      class="block w-full border rounded p-2"
    />

    <!-- HELPER TEXT -->
    <p class="text-sm text-gray-500 mt-1">
      Upload <strong>only 1 image</strong> (JPG, PNG)
    </p>

    <button
      type="submit"
      class="w-full bg-pink-600 text-white py-2 rounded-lg hover:bg-pink-700"
    >
      Submit for Verification
    </button>

  </form>
</div>