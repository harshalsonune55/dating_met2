<%- layout("/layouts/navbar.ejs") %>

<style>
  .contact-page {
    min-height: 60vh;
    background: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px 80px;
    text-align: center;
  }

  .contact-page h1 {
    font-size: 2.2rem;
    font-weight: 700;
    color: #222;
    margin-bottom: 24px;
  }

  .contact-desc {
    max-width: 640px;
    font-size: 1rem;
    color: #444;
    line-height: 1.75;
    margin-bottom: 20px;
  }

  .contact-desc a.faq-link {
    color: #c0392b;
    text-decoration: none;
    font-weight: 500;
  }
  .contact-desc a.faq-link:hover { text-decoration: underline; }

  .contact-desc .email-highlight {
    font-weight: 700;
    color: #111;
  }

  /* Dot divider */
  .dot-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 18px 0 32px;
  }
  .dot-divider span {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background: #bbb;
    display: inline-block;
  }
  .dot-divider span.active {
    background: #555;
  }

  /* Chat Now button */
  .btn-chat-now {
    display: inline-block;
    background: #c0392b;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
    padding: 14px 52px;
    border-radius: 6px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.18s;
    letter-spacing: 0.3px;
  }
  .btn-chat-now:hover { background: #a93226; }

  /* ── Footer ── */
  .contact-footer {
    background: #c0392b;
    color: #fff;
    padding: 30px 20px 0;
    text-align: center;
  }

  .contact-footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px 4px;
    font-size: 0.9rem;
    margin-bottom: 18px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }
  .contact-footer-links a {
    color: #fff;
    text-decoration: underline;
    font-weight: 400;
  }
  .contact-footer-links a:hover { color: #ffe0cc; }
  .contact-footer-links .sep {
    color: rgba(255,255,255,0.55);
    margin: 0 2px;
  }

  .contact-footer-social {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 22px;
    padding: 16px 0;
  }
  .contact-footer-social a {
    color: #fff;
    font-size: 1.45rem;
    text-decoration: none;
    transition: opacity 0.18s;
  }
  .contact-footer-social a:hover { opacity: 0.75; }

  .contact-footer-copy {
    background: #a93226;
    padding: 13px 20px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.85);
    margin-top: 4px;
  }
</style>

<!-- ── CONTACT BODY ── -->
<div class="contact-page">
  <h1>Contact Us</h1>

  <p class="contact-desc">
    Did you know most of your questions can be answered by visiting our
    <a href="/#faq" class="faq-link">Frequently Asked Questions</a>
    page. For answers immediately, check out&nbsp;
    <span class="email-highlight">Mail us on :- care@datingmet.com</span>
  </p>

  <!-- Dot divider -->
  <div class="dot-divider">
    <span></span>
    <span class="active"></span>
    <span></span>
  </div>

  <a href="/inbox" class="btn-chat-now">Chat Now</a>
</div>

<!-- ── CONTACT FOOTER ── -->
<div class="contact-footer">
  <div class="contact-footer-links">
    <a href="/people">Browse Profiles</a>
    <span class="sep">-</span>
    <a href="/blogs">DatingMet Blog</a>
    <span class="sep">-</span>
    <a href="/privacy-policy">Privacy Policy</a>
    <span class="sep">-</span>
    <a href="/safety-policy">Safety Policy</a>
    <span class="sep">-</span>
    <a href="/child-safety">Child Safety</a>
    <span class="sep">-</span>
    <a href="/terms-of-use">Terms of Use</a>
    <span class="sep">-</span>
    <a href="/contact-us">Contact Us</a>
    <span class="sep">-</span>
    <a href="/report-vulnerability">Report Vulnerability</a>
  </div>

  <div class="contact-footer-social">
    <a href="https://www.facebook.com/" target="_blank" aria-label="Facebook">
      <i class="fa-brands fa-facebook-f"></i>
    </a>
    <a href="https://www.youtube.com/" target="_blank" aria-label="YouTube">
      <i class="fa-brands fa-youtube"></i>
    </a>
    <a href="https://www.twitter.com/" target="_blank" aria-label="Twitter">
      <i class="fa-brands fa-twitter"></i>
    </a>
  </div>

  <div class="contact-footer-copy">
    Copyright &copy; 2026 DatingMet.com &ndash; A product of NEXETERN. All rights reserved.
  </div>
</div>
