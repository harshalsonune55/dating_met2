<%- layout("layouts/navbar.ejs") %>

<div class="max-w-5xl mx-auto p-6">
  <div class="bg-white rounded-2xl shadow p-8">

    <!-- HEADER -->
    <div class="flex items-center gap-6 mb-6">
      <img
        src="<%= profile.image || 'https://ui-avatars.com/api/?name=' + profile.first_name %>"
        alt="Profile Image"
        class="w-28 h-28 rounded-full border object-cover"
      />

      <div>
        <h1 class="text-3xl font-bold text-gray-900">
          <%= profile.first_name %> <%= profile.last_name %>
        </h1>

        <p class="text-gray-600">
          <%= profile.work || "—" %>
        </p>

        <p class="text-gray-500 text-sm">
          📍 <%= profile.address || "Not specified" %>
        </p>

        <!-- PHONE NUMBER -->
        <p class="text-gray-700 mt-1">
          📞 <strong><%= phone || "Not available" %></strong>
        </p>
        <!-- EDIT PROFILE BUTTON -->
<div class="mt-3">
  <a
    href="/admin/profile/<%= profile._id %>/edit"
    class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg
           font-semibold hover:bg-blue-700 transition shadow"
  >
    ✏️ Edit Profile
  </a>
  <a
    href="/admin/profile/<%= profile._id %>/matchmaking/edit"
    class="bg-purple-600 text-white px-4 py-2 rounded-lg
           font-semibold hover:bg-purple-700 transition shadow"
  >
    🧬 Edit Matchmaking
  </a>
</div>
      </div>
    </div>

    <hr class="my-6" />

    <!-- ABOUT -->
    <h2 class="text-xl font-semibold text-gray-900 mb-2">About</h2>
    <p class="text-gray-700 mb-6 leading-relaxed">
      <%= profile.about || "No about section provided." %>
    </p>
    <% if (profile.govtIdImages && profile.govtIdImages.length && !profile.isVerified) { %>
      <hr class="my-6" />
    
      <h2 class="text-xl font-semibold mb-3">Government ID Documents</h2>
    
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 mb-6">
        <% profile.govtIdImages.forEach((img) => { %>
          <div class="border rounded-xl overflow-hidden shadow-sm">
            <img
              src="<%= img %>"
              alt="Government ID"
              class="w-full h-48 object-cover hover:scale-105 transition-transform"
            />
          </div>
        <% }) %>
      </div>
    
      <form action="/admin/verify/<%= profile._id %>" method="POST">
        <button
          class="bg-green-600 text-white px-6 py-3 rounded-lg font-semibold
                 hover:bg-green-700 transition shadow"
        >
          ✅ Approve Verification
        </button>
      </form>
    <% } %>
    
    

    <!-- EXPERTISE & INTERESTS -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- EXPERTISE -->
      <div>
        <h3 class="font-semibold text-gray-900 mb-2">Expertise</h3>
        <div class="flex flex-wrap gap-2">
          <% if (profile.expertise && profile.expertise.length) { %>
            <% profile.expertise.forEach(e => { %>
              <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm">
                #<%= e %>
              </span>
            <% }) %>
          <% } else { %>
            <p class="text-gray-500 text-sm">No expertise added</p>
          <% } %>
        </div>
      </div>

      <!-- INTERESTS -->
      <div>
        <h3 class="font-semibold text-gray-900 mb-2">Interests</h3>
        <div class="flex flex-wrap gap-2">
          <% if (profile.interests && profile.interests.length) { %>
            <% profile.interests.forEach(i => { %>
              <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm">
                #<%= i %>
              </span>
            <% }) %>
          <% } else { %>
            <p class="text-gray-500 text-sm">No interests added</p>
          <% } %>
        </div>
      </div>

    </div>

    <!-- MEMBERSHIP STATUS -->
    <div class="mt-8">
      <p class="text-gray-800">
        <p class="text-gray-800">
          <strong>Membership:</strong>
        
          <% if (profile.isSubscribed) { %>
        
            <span class="text-green-600 font-semibold ml-1">
              Active
            </span>
        
            <!-- PLAN BADGE -->
            <span class="ml-2 px-3 py-1 rounded-full text-xs font-semibold
              <%= profile.subscriptionPlan === 'Basic' ? 'bg-blue-100 text-blue-700'
              : profile.subscriptionPlan === 'standard' ? 'bg-purple-100 text-purple-700'
              : profile.subscriptionPlan === 'Premium' ? 'bg-yellow-100 text-yellow-700'
              : profile.subscriptionPlan.includes('Elite') ? 'bg-pink-100 text-pink-700'
              : profile.subscriptionPlan.includes('NRI') ? 'bg-indigo-100 text-indigo-700'
              : 'bg-gray-100 text-gray-700' %>
            ">
              💎 <%= profile.subscriptionPlan %>
            </span>
        
          <% } else { %>
        
            <span class="text-gray-500 font-semibold ml-1">Inactive</span>
        
          <% } %>
        </p>
      </p>
    </div>
    <div class="mt-6 bg-yellow-50 border border-yellow-300 p-4 rounded-xl shadow-sm">
      <h3 class="font-semibold text-gray-800 mb-2">🪙 Coin Balance</h3>
    
      <p class="text-2xl font-bold text-yellow-600">
        <%= profile.callTokens || 0 %> Coins
      </p>
    
      <p class="text-xs text-gray-500 mt-1">
        Use coins for voice/video calls
      </p>
    </div>
    <hr class="my-8" />

<div class="bg-gray-50 border rounded-xl p-6 shadow-sm">

  <h2 class="text-xl font-semibold mb-4">⚙️ Admin Controls</h2>

  <form action="/admin/profile/<%= profile._id %>/update-membership" method="POST" class="space-y-4">

    <!-- PLAN -->
    <div>
      <label class="block text-sm font-semibold mb-1">Subscription Plan</label>
      <select name="subscriptionPlan" class="w-full border px-3 py-2 rounded">
        <option value="">None</option>
        <option value="Basic" <%= profile.subscriptionPlan === "Basic" ? "selected" : "" %>>Basic</option>
        <option value="Standard" <%= profile.subscriptionPlan === "Standard" ? "selected" : "" %>>Standard</option>
        <option value="Premium" <%= profile.subscriptionPlan === "Premium" ? "selected" : "" %>>Premium</option>
        <option value="Elite-3" <%= profile.subscriptionPlan === "Elite-3" ? "selected" : "" %>>Elite 3 Months</option>
        <option value="Elite-6" <%= profile.subscriptionPlan === "Elite-6" ? "selected" : "" %>>Elite 6 Months</option>
        <option value="NRI-3" <%= profile.subscriptionPlan === "NRI-3" ? "selected" : "" %>>NRI 3 Months</option>
        <option value="NRI-6" <%= profile.subscriptionPlan === "NRI-6" ? "selected" : "" %>>NRI 6 Months</option>
      </select>
    </div>

    <!-- COINS -->
    <div>
      <label class="block text-sm font-semibold mb-1">Coins (Call Tokens)</label>
      <input
        type="number"
        name="callTokens"
        value="<%= profile.callTokens || 0 %>"
        class="w-full border px-3 py-2 rounded"
      />
    </div>

    <!-- DURATION -->
    <div>
      <label class="block text-sm font-semibold mb-1">Duration (Months)</label>
      <input
        type="number"
        name="duration"
        placeholder="e.g. 1"
        class="w-full border px-3 py-2 rounded"
      />
    </div>

    <!-- BUTTON -->
    <button
      type="submit"
      class="w-full bg-green-600 text-white py-3 rounded-lg font-semibold hover:bg-green-700 transition"
    >
      💾 Update Membership & Coins
    </button>

  </form>
</div>

    <% if (profile.isSubscribed) { %>
      <div class="mt-4 bg-green-50 border border-green-200 p-4 rounded-lg">
    
        <p class="text-gray-800">
          <strong>📅 Subscription Started:</strong>
          <%= profile.subscriptionStartedAt 
            ? new Date(profile.subscriptionStartedAt).toLocaleDateString("en-IN", {
                day: "2-digit",
                month: "long",
                year: "numeric"
              })
            : "—" %>
        </p>
    
        <p class="text-gray-800 mt-1">
          <strong>⏳ Expiry Date:</strong>
          <%= profile.subscriptionExpiresAt 
            ? new Date(profile.subscriptionExpiresAt).toLocaleDateString("en-IN", {
                day: "2-digit",
                month: "long",
                year: "numeric"
              })
            : "—" %>
        </p>
    
        <% if (profile.subscriptionExpiresAt) { %>
          <p class="text-sm mt-2 font-medium
            <%= new Date(profile.subscriptionExpiresAt) < new Date() 
                ? 'text-red-600' 
                : 'text-green-600' %>">
    
            <%= new Date(profile.subscriptionExpiresAt) < new Date()
              ? "⚠️ Plan Expired"
              : "✅ Active Plan" %>
    
          </p>
        <% } %>
    
      </div>
    <% } %>

    <!-- DELETE PROFILE (ADMIN ONLY) -->
<div class="mt-10 border-t pt-6">
  <form
    action="/admin/profile/<%= profile._id %>/delete"
    method="POST"
    onsubmit="return confirm('⚠️ Are you sure you want to permanently delete this profile? This action cannot be undone.')"
  >
    <button
      type="submit"
      class="bg-red-600 text-white px-6 py-3 rounded-lg font-semibold
             hover:bg-red-700 transition shadow"
    >
      🗑 Delete Profile
    </button>
  </form>
</div>


    <!-- BACK LINK -->
    <div class="mt-8">
      <a
        href="/profiles"
        class="inline-block text-blue-600 hover:underline font-medium"
      >
        ← Back to Profiles
      </a>
    </div>

  </div>
</div>
