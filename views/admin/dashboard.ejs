<%- layout("layouts/navbar.ejs") %>

<div class="max-w-6xl mx-auto p-6">
  <h1 class="text-3xl font-bold mb-8">Admin Dashboard</h1>

  <!-- STATS GRID -->
  <div class="grid grid-cols-1 md:grid-cols-6 gap-6">

    <div class="bg-white p-6 rounded-xl shadow">
      <p class="text-gray-500 mb-1">Total Profiles</p>
      <p class="text-4xl font-bold text-blue-600"><%= totalProfiles %></p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow">
      <p class="text-gray-500 mb-1">Incomplete Profiles</p>
      <p class="text-4xl font-bold text-red-600"><%= incompleteProfiles %></p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow">
      <p class="text-gray-500 mb-1">Active Memberships</p>
      <p class="text-4xl font-bold text-green-600"><%= activeMembers %></p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow">
      <p class="text-gray-500 mb-1">Inactive Memberships</p>
      <p class="text-4xl font-bold text-gray-600"><%= inactiveMembers %></p>
    </div>
    <!-- ✅ VERIFIED -->
  <div class="bg-white p-6 rounded-xl shadow border border-blue-200">
    <p class="text-gray-500 mb-1">Verified Profiles</p>
    <p class="text-4xl font-bold text-blue-700"><%= verifiedProfiles %></p>
  </div>

  <!-- ⏳ PENDING VERIFICATION -->
  <div class="bg-gradient-to-br from-yellow-50 to-yellow-100 p-6 rounded-xl shadow border border-yellow-300">
    <p class="text-gray-600 mb-1 font-medium">⏳ Pending Verification</p>
    <p class="text-4xl font-bold text-yellow-700"><%= pendingVerifications %></p>
    <p class="text-xs text-yellow-700 mt-1">
      Awaiting admin approval
    </p>
  </div>
  

    <!-- 📝 BLOG CARD -->
    

  </div>

  <!-- ACTION BUTTONS -->
 <!-- ACTION BUTTONS -->
<div class="mt-10 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">

  <!-- ✅ CREATE PROFILE -->
  <a
    href="/admin/create-user-full"
    class="text-center bg-green-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-700 transition shadow"
  >
    ➕ Create Profile
  </a>

  <!-- VIEW ALL PROFILES -->
  <a
    href="/profiles"
    class="text-center bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow"
  >
    👥 View All Profiles
  </a>

  <!-- ADD BLOG -->
  <a
    href="/admin/blogs/new"
    class="text-center bg-pink-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-pink-700 transition shadow"
  >
    ✍️ Add New Blog
  </a>
  <a
  href="/admin/create-makeup-user"
  class="text-center bg-purple-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-purple-700 transition shadow"
>
  👤 Create Makeup User
</a>

  <!-- VIEW BLOGS -->
  <a
    href="/blogs"
    class="text-center bg-gray-800 text-white px-6 py-3 rounded-lg font-semibold hover:bg-gray-900 transition shadow"
  >
    📚 View Blogs
  </a>

</div>
  <br/>
  <br/>

<!-- 🔔 NOTIFICATIONS SECTION -->
<div class="mt-10 bg-white p-6 rounded-xl shadow">
  <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
    🔔 Recent Notifications
  </h2>

  <% if (notifications && notifications.length) { %>
    <ul class="space-y-3">

      <% notifications.forEach(n => { %>
        <li class="flex justify-between items-center border-b pb-2">

          <div>
            <p class="text-gray-800 font-medium">
              <%= n.message %>
            </p>

            <p class="text-sm text-gray-500">
              📞 <%= n.userPhone %> • 
              <%= new Date(n.createdAt).toLocaleString() %>
            </p>
          </div>

          <% if (!n.isRead) { %>
            <span class="text-xs bg-red-500 text-white px-2 py-1 rounded">
              NEW
            </span>
          <% } %>

        </li>
      <% }) %>

    </ul>
  <% } else { %>
    <p class="text-gray-500">No notifications yet</p>
  <% } %>
</div>
</div>



