<%- layout("layouts/navbar.ejs") %>

<div class="max-w-xl mx-auto mt-12 bg-white p-8 rounded-2xl shadow">

  <h2 class="text-2xl font-bold mb-6 text-center">
    👤 Create Makeup User
  </h2>

  <% if (typeof error !== "undefined") { %>
    <p class="text-red-500 text-center mb-4">
      <%= error %>
    </p>
  <% } %>

  <% if (typeof success !== "undefined") { %>
    <p class="text-green-600 text-center mb-4">
      <%= success %>
    </p>
  <% } %>

  <form action="/admin/create-makeup-user" method="POST" class="space-y-5">

    <!-- PHONE -->
    <div>
      <label class="block text-sm font-medium mb-1">
        Phone Number
      </label>
      <input
        type="text"
        name="phone"
        required
        placeholder="Enter phone number"
        class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-blue-500"
      />
    </div>

    <!-- PASSWORD -->
    <div>
      <label class="block text-sm font-medium mb-1">
        Password
      </label>
      <input
        type="password"
        name="password"
        required
        placeholder="Enter password"
        class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-blue-500"
      />
    </div>

    <!-- CONFIRM PASSWORD -->
    <div>
      <label class="block text-sm font-medium mb-1">
        Confirm Password
      </label>
      <input
        type="password"
        name="confirmPassword"
        required
        placeholder="Confirm password"
        class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-blue-500"
      />
    </div>

    <!-- SUBMIT BUTTON -->
    <button
      type="submit"
      class="w-full bg-green-600 text-white py-3 rounded-lg font-semibold hover:bg-green-700 transition"
    >
      ➕ Create Makeup User
    </button>

  </form>

  <!-- INFO BOX -->
  <div class="mt-6 text-sm text-gray-500 text-center">
    This user will login using password instead of OTP.
  </div>

</div>