<%- layout("layouts/navbar.ejs") %>

<div class="max-w-3xl mx-auto p-6">

  <!-- Header -->
  <div class="flex items-center gap-4 mb-6">
    <a href="/admin/profile/<%= profile._id %>/chats" class="text-blue-600 hover:underline text-sm">
      ← Back to Conversations
    </a>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">
        Chat with <%= otherProfile.first_name %> <%= otherProfile.last_name || '' %>
      </h1>
      <p class="text-gray-500 text-sm">
        <%= profile.first_name %> (<%= profile.phone %>)
        &nbsp;↔&nbsp;
        <%= otherProfile.first_name %> (<%= otherProfile.phone %>)
      </p>
    </div>
  </div>

  <!-- Participants -->
  <div class="flex gap-4 mb-6">
    <div class="flex items-center gap-2 bg-pink-50 border border-pink-200 rounded-xl px-4 py-2">
      <img
        src="<%= profile.image || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(profile.first_name) %>"
        class="w-10 h-10 rounded-full object-cover"
      />
      <div>
        <p class="font-semibold text-sm text-gray-900"><%= profile.first_name %></p>
        <p class="text-xs text-gray-500"><%= profile.phone %></p>
      </div>
    </div>
    <div class="flex items-center gap-2 bg-gray-50 border rounded-xl px-4 py-2">
      <img
        src="<%= otherProfile.image || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(otherProfile.first_name) %>"
        class="w-10 h-10 rounded-full object-cover"
      />
      <div>
        <p class="font-semibold text-sm text-gray-900"><%= otherProfile.first_name %></p>
        <p class="text-xs text-gray-500"><%= otherProfile.phone %></p>
      </div>
    </div>
  </div>

  <!-- Messages -->
  <div class="bg-white border rounded-xl p-4 space-y-3 min-h-[200px]">
    <% if (messages.length === 0) { %>
      <p class="text-gray-400 text-center py-10">No messages found.</p>
    <% } else { %>
      <% messages.forEach(msg => { %>
        <% const isMine = msg.senderPhone === myPhone; %>
        <div class="flex <%= isMine ? 'justify-end' : 'justify-start' %>">
          <div class="max-w-[70%]">
            <div class="
              px-4 py-2 rounded-2xl text-sm
              <%= isMine
                ? 'bg-pink-500 text-white rounded-br-none'
                : 'bg-gray-100 text-gray-800 rounded-bl-none' %>
            ">
              <%= msg.message %>
            </div>
            <p class="text-xs text-gray-400 mt-1 <%= isMine ? 'text-right' : 'text-left' %>">
              <%= new Date(msg.createdAt).toLocaleString("en-IN", {
                day: "2-digit", month: "short", year: "numeric",
                hour: "2-digit", minute: "2-digit"
              }) %>
            </p>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <p class="text-xs text-gray-400 text-center mt-3">
    Total messages: <%= messages.length %>
  </p>

</div>
